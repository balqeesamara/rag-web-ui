# OpenAI-compatible API (LM Studio, OpenAI, etc.)
OPENAI_API_KEY=***
OPENAI_API_BASE=https://api.openai.com/v1

# Response generation model (used for RAG answers)
OPENAI_MODEL=qwen/qwen3.5-9b

# Query-rewriting and summarisation model — smaller/faster is fine.
# Omit or leave empty to reuse OPENAI_MODEL.
OPENAI_QUERY_MODEL=qwen/qwen3.5-4b

# Vision model for markitdown-ocr (OCR of scanned PDFs / embedded images).
# Must be a multimodal model.  Leave empty to disable OCR.
OPENAI_VISION_MODEL=qwen/qwen3.5-4b
# OPENAI_VISION_API_BASE=  # override base URL for the vision model; defaults to OPENAI_API_BASE

# Embeddings model
OPENAI_EMBEDDINGS_MODEL=qwen/qwen3-embedding-0.6b

# File storage
UPLOAD_DIR=/app/uploads

# Retrieval
RETRIEVAL_TOP_K=6
# Minimum RRF score threshold — chunks below this are dropped before the LLM sees them.
# RRF scores for a 3-leg setup (K=60) range roughly 0.003–0.02.
# Increase to 0.007 or 0.008 if irrelevant chunks from unrelated documents appear.
# Set to 0.0 to disable.
RETRIEVAL_MIN_RRF_SCORE=0.005

# Cross-encoder reranker — re-scores RRF candidates with ms-marco MiniLM-L-12
# More accurate than RRF threshold alone for cross-document disambiguation.
# Set RERANKER_ENABLED=false to disable (falls back to RRF order).
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
RERANKER_CACHE_DIR=/app/assets/reranker
RERANKER_TOP_N=5

# Chunking
# WARNING: changing these values after documents have been ingested creates
# inconsistent chunk sizes across the knowledge base. If you change them,
# delete and re-upload all existing documents to re-index with the new settings.
#
# CHUNK_SIZE: target chunk size in characters. Keep <= 1800 chars when using
# SPLADE (prithivida/Splade_PP_en_v1) — BERT's 512-token limit means longer
# chunks are silently truncated in the sparse leg (~4 chars/token for English).
CHUNK_SIZE=1500
# OVERLAP_PERCENTAGE: fraction of chunk_size repeated at the start of the next
# chunk (0.0–1.0). 0.20 = 20% overlap = 300 chars at chunk_size=1500.
OVERLAP_PERCENTAGE=0.20

# Hybrid search weights (dense=Qdrant cosine, qdrant_sparse=SPLADE, exact=MySQL FTS)
HYBRID_DENSE_WEIGHT=0.5
HYBRID_QDRANT_SPARSE_WEIGHT=0.3
HYBRID_EXACT_WEIGHT=0.2
# Per-leg enable/disable (ingestion always indexes all three regardless)
RETRIEVAL_DENSE_ENABLED=true
RETRIEVAL_QDRANT_SPARSE_ENABLED=true
RETRIEVAL_EXACT_ENABLED=true

# Neo4j / GraphRAG
# WARNING: NEO4J_URI uses service name 'neo4j' — only works inside Docker network.
# For local dev without Docker, use bolt://localhost:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ragwebui_neo4j

# Set false to skip graph extraction during document ingestion (saves LLM calls).
# Documents will still be fully searchable via the 3-leg hybrid pipeline.
GRAPHRAG_ENABLED=true

# Model for entity/relationship extraction at ingest time.
# Defaults to OPENAI_MODEL when unset. A smaller/cheaper model works well here.
GRAPHRAG_LLM_MODEL=qwen/qwen3.5-4b

# Retrieval: enable/disable graph leg independently of ingestion.
RETRIEVAL_GRAPH_ENABLED=true

# Number of relationship hops to traverse from seed nodes at query time (1-3 recommended).

# RRF weight for the graph retrieval leg (alongside dense=0.5, sparse=0.3, exact=0.2).

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Dense embedding dimension (must match OPENAI_EMBEDDINGS_MODEL output)
DENSE_EMBEDDING_DIM=1024

# SPLADE sparse embedder (FastEmbed, CPU)
SPLADE_MODEL=prithivida/Splade_PP_en_v1
FASTEMBED_CACHE_DIR=./assets/fastembed

# MySQL
MYSQL_SERVER=db
MYSQL_PORT=3306
MYSQL_USER=ragwebui
MYSQL_PASSWORD=ragwebui
MYSQL_DATABASE=ragwebui

# JWT
SECRET_KEY=your-secret-key-here
TIMEOUT_SECONDS=30000

# Timezone
# All services run in UTC. Do not change this — timestamps are stored as UTC
# in the DB and the frontend converts to the user's local timezone automatically.
TZ=UTC
