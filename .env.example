# OpenAI-compatible API (LM Studio, OpenAI, etc.)
OPENAI_API_KEY=***
OPENAI_API_BASE=https://api.openai.com/v1

# Response generation model (used for RAG answers)
OPENAI_MODEL=gpt-4o

# Query-rewriting and summarisation model — smaller/faster is fine.
# Omit or leave empty to reuse OPENAI_MODEL.
# OPENAI_QUERY_MODEL=gpt-4o-mini

# Vision model for markitdown-ocr (OCR of scanned PDFs / embedded images).
# Must be a multimodal model.  Leave empty to disable OCR.
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_VISION_API_BASE=  # override base URL for the vision model; defaults to OPENAI_API_BASE

# Embeddings model
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# File storage
UPLOAD_DIR=/app/uploads

# Retrieval
RETRIEVAL_TOP_K=6

# Chunking
# WARNING: changing these values after documents have been ingested creates
# inconsistent chunk sizes across the knowledge base. If you change them,
# delete and re-upload all existing documents to re-index with the new settings.
#
# CHUNK_SIZE: target chunk size in characters. Keep <= 1800 chars when using
# SPLADE (prithivida/Splade_PP_en_v1) — BERT's 512-token limit means longer
# chunks are silently truncated in the sparse leg (~4 chars/token for English).
CHUNK_SIZE=1500
# OVERLAP_PERCENTAGE: fraction of chunk_size repeated at the start of the next
# chunk (0.0–1.0). 0.20 = 20% overlap = 300 chars at chunk_size=1500.
OVERLAP_PERCENTAGE=0.20

# Hybrid search weights (dense=Qdrant cosine, qdrant_sparse=SPLADE, exact=MySQL FTS)
HYBRID_DENSE_WEIGHT=0.5
HYBRID_QDRANT_SPARSE_WEIGHT=0.3
HYBRID_EXACT_WEIGHT=0.2
# Per-leg enable/disable (ingestion always indexes all three regardless)
RETRIEVAL_DENSE_ENABLED=true
RETRIEVAL_QDRANT_SPARSE_ENABLED=true
RETRIEVAL_EXACT_ENABLED=true

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Dense embedding dimension (must match OPENAI_EMBEDDINGS_MODEL output)
DENSE_EMBEDDING_DIM=1024

# SPLADE sparse embedder (FastEmbed, CPU)
SPLADE_MODEL=prithivida/Splade_PP_en_v1
FASTEMBED_CACHE_DIR=./assets/fastembed

# MySQL
MYSQL_SERVER=db
MYSQL_PORT=3306
MYSQL_USER=ragwebui
MYSQL_PASSWORD=ragwebui
MYSQL_DATABASE=ragwebui

# JWT
SECRET_KEY=your-secret-key-here
